          { "name": "Body", "value": "={{ 'Last note, ' + $('Extract Lead').item.json.leadName + ' — if now isn\\'t the time, no worries. When you\\'re ready to stop leaking leads, I\\'m one reply away. ' + $('Config — edit me').item.json.bookingLink }}" }
        ] },
        "options": {}
      },
      "id": "http10",
      "name": "Day 10 — Last Call",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [2420, 480]
    }

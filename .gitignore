# Secrets — NEVER commit
.env
*.env
**/token*.json
**/client_secret*.json

# Python
.venv/
__pycache__/
*.pyc
*.pyo

# Data / DB
data/*.db
data/*.sqlite

# Raw stock cache (2.3GB, regenerable from Pexels)
assets/broll/*
assets/music/*
assets/thumbnails/*
!assets/**/.gitkeep

# Render intermediates (keep final .mp4 deliverables, drop scratch files)
renders/*.vo.mp3
renders/*.captions.ass

# Packaging artifacts (zips built from tracked source for upload)
content/product/*.zip

# OS
.DS_Store
desktop.ini
Thumbs.db

# Tooling
.claude-flow/
.swarm/
.serena/
